<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>AquaCraft Shop</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet"/>
<script src="https://www.paypal.com/sdk/js?client-id=AYXUbfwNYB9SRzos-JMC3XLAuJWKtcG9b5VOshDLNBP1JStx4DJidvskDn2b8StHFzP61sA2U6-VjDqS&currency=EUR&locale=fr_FR"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#050d1a;
  --bg2:#0a1628;
  --blue:#00aaff;
  --cyan:#00ffee;
  --gold:#ffd700;
  --purple:#a855f7;
  --green:#00ff88;
  --red:#ff4455;
  --text:#e0f0ff;
  --muted:#5a7a9a;
  --card:#0d1f35;
  --border:rgba(0,170,255,0.2);
}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Exo 2',sans-serif;
  font-weight:300;
  min-height:100vh;
  overflow-x:hidden;
  cursor:default;
}

/* ── BACKGROUND STARS ── */
body::before{
  content:'';
  position:fixed;inset:0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(0,100,255,0.08) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(100,0,255,0.06) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 100%, rgba(0,200,255,0.05) 0%, transparent 60%);
  pointer-events:none;z-index:0;
}
canvas#stars{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:0.6}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  display:flex;justify-content:space-between;align-items:center;
  padding:1rem 3rem;
  background:rgba(5,13,26,0.9);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
}
.logo{
  font-family:'Orbitron',monospace;
  font-size:1.4rem;font-weight:900;
  background:linear-gradient(90deg,var(--blue),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  letter-spacing:0.1em;
}
.logo span{color:var(--gold);-webkit-text-fill-color:var(--gold)}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{
  font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;
  color:var(--muted);text-decoration:none;transition:color 0.3s;
}
.nav-links a:hover{color:var(--cyan)}
.nav-pseudo{
  font-size:0.7rem;color:var(--cyan);
  border:1px solid var(--border);
  padding:0.3rem 0.8rem;border-radius:20px;
  display:none;
}

/* ── HERO ── */
.hero{
  position:relative;z-index:1;
  min-height:100vh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;
  padding:6rem 2rem 4rem;
}
.hero-badge{
  font-size:0.65rem;letter-spacing:0.4em;text-transform:uppercase;
  color:var(--cyan);border:1px solid rgba(0,255,238,0.3);
  padding:0.35rem 1.2rem;border-radius:20px;
  margin-bottom:2rem;
  animation:pulse-border 3s ease infinite;
}
@keyframes pulse-border{
  0%,100%{box-shadow:0 0 0 0 rgba(0,255,238,0.3)}
  50%{box-shadow:0 0 0 8px rgba(0,255,238,0)}
}
.hero h1{
  font-family:'Orbitron',monospace;
  font-size:clamp(2.5rem,7vw,6rem);
  font-weight:900;
  line-height:1;
  margin-bottom:0.3rem;
  text-shadow:0 0 60px rgba(0,170,255,0.5);
}
.hero h1 .water{
  background:linear-gradient(90deg,#00aaff,#00ffee,#00aaff);
  background-size:200%;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  animation:shimmer 4s linear infinite;
}
@keyframes shimmer{0%{background-position:0%}100%{background-position:200%}}
.hero h1 .craft{color:#fff}
.hero-shop{
  font-family:'Orbitron',monospace;
  font-size:clamp(1rem,2.5vw,2rem);
  color:var(--gold);letter-spacing:0.5em;
  margin-bottom:1.5rem;
  text-shadow:0 0 20px rgba(255,215,0,0.5);
}
.hero-sub{
  font-size:0.9rem;color:var(--muted);max-width:500px;
  line-height:1.8;margin-bottom:3rem;
}
.hero-buttons{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
.btn-primary{
  padding:0.85rem 2.5rem;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#050d1a;font-family:'Orbitron',monospace;
  font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;
  border:none;cursor:pointer;clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);
  transition:all 0.3s;text-decoration:none;
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,170,255,0.4)}
.btn-secondary{
  padding:0.85rem 2.5rem;
  background:transparent;
  color:var(--cyan);font-family:'Orbitron',monospace;
  font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;
  border:1px solid var(--cyan);cursor:pointer;
  clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%);
  transition:all 0.3s;text-decoration:none;display:inline-block;
}
.btn-secondary:hover{background:rgba(0,255,238,0.1);transform:translateY(-2px)}

/* SCROLL INDICATOR */
.scroll-hint{
  position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:0.5rem;
  color:var(--muted);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;
}
.scroll-arrow{
  width:20px;height:20px;border-right:2px solid var(--muted);border-bottom:2px solid var(--muted);
  transform:rotate(45deg);animation:bounce 2s ease infinite;
}
@keyframes bounce{0%,100%{transform:rotate(45deg) translateY(0)}50%{transform:rotate(45deg) translateY(5px)}}

/* ── PSEUDO STEP ── */
#pseudo-step{
  position:relative;z-index:1;
  padding:5rem 2rem;
  display:flex;flex-direction:column;align-items:center;
}
.section-title{
  font-family:'Orbitron',monospace;
  font-size:clamp(1.2rem,3vw,2rem);
  font-weight:700;
  text-align:center;
  margin-bottom:0.5rem;
  background:linear-gradient(90deg,var(--blue),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.section-sub{text-align:center;color:var(--muted);font-size:0.8rem;margin-bottom:3rem;line-height:1.8}

.pseudo-card{
  background:var(--card);
  border:1px solid var(--border);
  border-radius:16px;
  padding:3rem;
  max-width:480px;width:100%;
  position:relative;overflow:hidden;
  box-shadow:0 0 60px rgba(0,100,255,0.1);
}
.pseudo-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--blue),var(--cyan),var(--purple));
}
.pseudo-label{
  display:block;font-size:0.7rem;letter-spacing:0.2em;text-transform:uppercase;
  color:var(--cyan);margin-bottom:0.75rem;
}
.pseudo-input-wrap{position:relative;margin-bottom:0.5rem}
.pseudo-input{
  width:100%;padding:1rem 1.2rem;
  background:rgba(0,170,255,0.05);
  border:1px solid var(--border);border-radius:8px;
  color:var(--text);font-family:'Exo 2',sans-serif;font-size:1rem;
  outline:none;transition:all 0.3s;
}
.pseudo-input:focus{border-color:var(--cyan);box-shadow:0 0 20px rgba(0,255,238,0.15)}
.pseudo-hint{font-size:0.65rem;color:var(--muted);margin-bottom:1.5rem}
.btn-validate{
  width:100%;padding:1rem;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#050d1a;font-family:'Orbitron',monospace;
  font-size:0.75rem;font-weight:700;letter-spacing:0.15em;
  border:none;cursor:pointer;border-radius:8px;
  transition:all 0.3s;text-transform:uppercase;
}
.btn-validate:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(0,170,255,0.4)}
.btn-validate:disabled{opacity:0.4;cursor:not-allowed;transform:none}

.pseudo-confirmed{
  display:none;
  align-items:center;gap:1rem;
  background:rgba(0,255,136,0.1);border:1px solid rgba(0,255,136,0.3);
  border-radius:8px;padding:1rem;margin-top:1rem;
}
.pseudo-confirmed .check{font-size:1.5rem}
.pseudo-confirmed-text{font-size:0.8rem;color:var(--green)}

/* ── SHOP ── */
#shop{
  position:relative;z-index:1;
  padding:4rem 2rem 6rem;
  max-width:1300px;margin:0 auto;
}
.shop-header{text-align:center;margin-bottom:4rem}
.current-pseudo-badge{
  display:inline-flex;align-items:center;gap:0.5rem;
  background:rgba(0,255,238,0.1);border:1px solid rgba(0,255,238,0.3);
  border-radius:20px;padding:0.4rem 1rem;
  font-size:0.7rem;color:var(--cyan);margin-bottom:1.5rem;
}

/* TAB NAV */
.tab-nav{
  display:flex;gap:0.5rem;justify-content:center;
  margin-bottom:3rem;flex-wrap:wrap;
}
.tab-btn{
  padding:0.6rem 1.8rem;
  background:transparent;border:1px solid var(--border);
  color:var(--muted);font-family:'Orbitron',monospace;
  font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  cursor:pointer;border-radius:6px;transition:all 0.3s;
}
.tab-btn:hover,.tab-btn.active{
  background:rgba(0,170,255,0.15);border-color:var(--blue);color:var(--cyan);
  box-shadow:0 0 20px rgba(0,170,255,0.2);
}

.tab-content{display:none}
.tab-content.active{display:block}

/* ── GRADE CARDS ── */
.grades-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;
}
.grade-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:16px;padding:2rem;
  position:relative;overflow:hidden;
  transition:all 0.3s;cursor:pointer;
}
.grade-card:hover{transform:translateY(-6px)}
.grade-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
}
.grade-card.vip::before{background:linear-gradient(90deg,#4fc3f7,#0288d1)}
.grade-card.vip-plus::before{background:linear-gradient(90deg,#ffd700,#ff8c00)}
.grade-card.celestia::before{background:linear-gradient(90deg,#a78bfa,#7c3aed)}
.grade-card.cosmique::before{background:linear-gradient(90deg,#f9a8d4,#ec4899,#a855f7)}
.grade-card.vip:hover{box-shadow:0 20px 60px rgba(79,195,247,0.25)}
.grade-card.vip-plus:hover{box-shadow:0 20px 60px rgba(255,215,0,0.25)}
.grade-card.celestia:hover{box-shadow:0 20px 60px rgba(167,139,250,0.25)}
.grade-card.cosmique:hover{box-shadow:0 20px 60px rgba(236,72,153,0.25)}

.grade-icon{font-size:3rem;margin-bottom:1rem;display:block;text-align:center}
.grade-name{
  font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:700;
  text-align:center;margin-bottom:0.3rem;
}
.grade-card.vip .grade-name{color:#4fc3f7}
.grade-card.vip-plus .grade-name{color:var(--gold)}
.grade-card.celestia .grade-name{color:#a78bfa}
.grade-card.cosmique .grade-name{color:#f472b6}

.grade-perks{list-style:none;margin:1rem 0 1.5rem;font-size:0.72rem;color:var(--muted);line-height:2}
.grade-perks li::before{content:'✦ ';color:var(--cyan)}
.grade-price{
  font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;
  text-align:center;margin-bottom:1.5rem;
  text-shadow:0 0 20px currentColor;
}
.grade-card.vip .grade-price{color:#4fc3f7}
.grade-card.vip-plus .grade-price{color:var(--gold)}
.grade-card.celestia .grade-price{color:#a78bfa}
.grade-card.cosmique .grade-price{color:#f472b6}

.btn-buy{
  width:100%;padding:0.85rem;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#050d1a;font-family:'Orbitron',monospace;
  font-size:0.65rem;font-weight:700;letter-spacing:0.1em;
  border:none;cursor:pointer;border-radius:8px;
  transition:all 0.3s;text-transform:uppercase;
}
.grade-card.vip-plus .btn-buy{background:linear-gradient(135deg,#ffd700,#ff8c00)}
.grade-card.celestia .btn-buy{background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff}
.grade-card.cosmique .btn-buy{background:linear-gradient(135deg,#ec4899,#a855f7);color:#fff}
.btn-buy:hover{transform:translateY(-2px);filter:brightness(1.1)}
.btn-buy:disabled{opacity:0.4;cursor:not-allowed;transform:none;filter:none}

/* ── KEYS SECTION ── */
.keys-intro{
  background:var(--card);border:1px solid var(--border);border-radius:16px;
  padding:2rem;margin-bottom:2.5rem;
  display:flex;align-items:flex-start;gap:1.5rem;flex-wrap:wrap;
}
.keys-intro-icon{font-size:2.5rem}
.keys-intro-text h3{
  font-family:'Orbitron',monospace;font-size:0.9rem;color:var(--cyan);margin-bottom:0.5rem;
}
.keys-intro-text p{font-size:0.75rem;color:var(--muted);line-height:1.8;max-width:600px}

.keys-category{margin-bottom:3rem}
.keys-cat-title{
  font-family:'Orbitron',monospace;font-size:0.8rem;letter-spacing:0.2em;
  text-transform:uppercase;color:var(--muted);
  margin-bottom:1.5rem;padding-bottom:0.5rem;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:0.75rem;
}
.keys-cat-title span{font-size:1.2rem}

.keys-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;
}
.key-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:1.5rem 1rem;
  text-align:center;position:relative;overflow:hidden;
  transition:all 0.3s;
}
.key-card:hover{transform:translateY(-4px)}
.key-icon{font-size:2.2rem;margin-bottom:0.75rem;display:block}
.key-name{
  font-family:'Orbitron',monospace;font-size:0.65rem;font-weight:700;
  letter-spacing:0.05em;margin-bottom:0.5rem;color:var(--text);
}
.key-rarity{font-size:0.6rem;color:var(--muted);margin-bottom:1rem}
.key-price{
  font-family:'Orbitron',monospace;font-size:1.3rem;font-weight:700;
  color:var(--cyan);margin-bottom:1rem;
}

/* qty control */
.qty-ctrl{
  display:flex;align-items:center;justify-content:center;gap:0;
  border:1px solid var(--border);border-radius:6px;overflow:hidden;
  margin-bottom:0.75rem;
}
.qty-minus,.qty-plus{
  background:rgba(0,170,255,0.1);border:none;color:var(--cyan);
  width:32px;height:32px;font-size:1.1rem;cursor:pointer;transition:background 0.2s;
}
.qty-minus:hover,.qty-plus:hover{background:rgba(0,170,255,0.25)}
.qty-val{
  flex:1;text-align:center;font-family:'Orbitron',monospace;
  font-size:0.8rem;color:var(--text);background:transparent;
  border:none;padding:0;line-height:32px;min-width:32px;
}

.btn-add-cart{
  width:100%;padding:0.6rem;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#050d1a;font-family:'Orbitron',monospace;
  font-size:0.58rem;font-weight:700;letter-spacing:0.08em;
  border:none;cursor:pointer;border-radius:6px;
  transition:all 0.3s;text-transform:uppercase;
}
.btn-add-cart:hover{transform:translateY(-1px);filter:brightness(1.1)}

/* key color variants */
.key-card.basic{border-color:rgba(100,200,255,0.2)}
.key-card.basic .key-price{color:#64c8ff}
.key-card.color{border-color:rgba(255,100,200,0.2)}
.key-card.color .key-price{color:#ff64c8}
.key-card.rainbow{border-color:transparent;background:linear-gradient(var(--card),var(--card)) padding-box,linear-gradient(135deg,#ff0080,#ff8800,#ffff00,#00ff80,#0080ff,#8000ff) border-box}
.key-card.rainbow .key-price{background:linear-gradient(90deg,#ff8800,#00ff80,#0080ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.key-card.vip-key{border-color:rgba(79,195,247,0.3)}
.key-card.vip-key .key-price{color:#4fc3f7}
.key-card.vip-plus-key{border-color:rgba(255,215,0,0.3)}
.key-card.vip-plus-key .key-price{color:var(--gold)}
.key-card.cosmique-key{border-color:rgba(236,72,153,0.3)}
.key-card.cosmique-key .key-price{background:linear-gradient(90deg,#ec4899,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.key-card.celestial-key{border-color:rgba(167,139,250,0.3)}
.key-card.celestial-key .key-price{color:#a78bfa}
.key-card.diamond{border-color:rgba(0,255,238,0.3)}
.key-card.diamond .key-price{color:var(--cyan)}
.key-card.utility{border-color:rgba(0,255,136,0.3)}
.key-card.utility .key-price{color:var(--green)}
.key-card.enchant{border-color:rgba(255,100,50,0.3)}
.key-card.enchant .key-price{color:#ff6432}

/* ── CART FLOATING ── */
#cart-fab{
  position:fixed;bottom:2rem;right:2rem;z-index:300;
  background:linear-gradient(135deg,var(--blue),var(--cyan));
  color:#050d1a;border:none;border-radius:50%;
  width:64px;height:64px;font-size:1.5rem;cursor:pointer;
  box-shadow:0 8px 32px rgba(0,170,255,0.4);
  display:flex;align-items:center;justify-content:center;
  transition:transform 0.3s;
}
#cart-fab:hover{transform:scale(1.1)}
#cart-count{
  position:absolute;top:-4px;right:-4px;
  background:var(--red);color:#fff;
  border-radius:50%;width:22px;height:22px;
  font-size:0.65rem;font-weight:700;font-family:'Orbitron',monospace;
  display:flex;align-items:center;justify-content:center;
  display:none;
}

/* ── CART MODAL ── */
.modal-overlay{
  position:fixed;inset:0;z-index:500;
  background:rgba(5,13,26,0.9);backdrop-filter:blur(8px);
  display:none;align-items:center;justify-content:center;padding:1rem;
}
.modal-overlay.open{display:flex}
.modal{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:20px;padding:2rem;max-width:620px;width:100%;
  max-height:90vh;overflow-y:auto;
  position:relative;
}
.modal-title{
  font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:700;
  color:var(--cyan);margin-bottom:1.5rem;
  display:flex;align-items:center;gap:0.75rem;
}
.modal-close{
  position:absolute;top:1.5rem;right:1.5rem;
  background:transparent;border:1px solid var(--border);
  color:var(--muted);width:32px;height:32px;border-radius:50%;
  cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;
}
.modal-close:hover{border-color:var(--red);color:var(--red)}

/* cart items */
.cart-empty{text-align:center;color:var(--muted);padding:3rem;font-size:0.8rem}
.cart-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:0.85rem 0;border-bottom:1px solid var(--border);gap:1rem;
  flex-wrap:wrap;
}
.cart-item-info{flex:1}
.cart-item-name{font-size:0.8rem;font-weight:600;color:var(--text);margin-bottom:0.2rem}
.cart-item-detail{font-size:0.65rem;color:var(--muted)}
.cart-item-qty{font-family:'Orbitron',monospace;font-size:0.7rem;color:var(--cyan)}
.cart-item-price{font-family:'Orbitron',monospace;font-size:0.9rem;font-weight:700;color:var(--gold)}
.cart-item-remove{
  background:transparent;border:1px solid rgba(255,68,85,0.3);
  color:var(--red);width:28px;height:28px;border-radius:50%;
  cursor:pointer;font-size:0.9rem;display:flex;align-items:center;justify-content:center;
  transition:all 0.2s;flex-shrink:0;
}
.cart-item-remove:hover{background:rgba(255,68,85,0.15)}

/* discount badge */
.discount-info{
  background:rgba(0,255,136,0.08);border:1px solid rgba(0,255,136,0.2);
  border-radius:8px;padding:0.75rem 1rem;margin:1rem 0;
  font-size:0.7rem;color:var(--green);line-height:1.7;
}
.discount-info strong{color:#fff}

.cart-total-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:1rem 0;border-top:2px solid var(--border);margin-top:0.5rem;
}
.cart-total-label{font-family:'Orbitron',monospace;font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.15em}
.cart-total-amount{font-family:'Orbitron',monospace;font-size:1.5rem;font-weight:900;color:var(--gold);text-shadow:0 0 20px rgba(255,215,0,0.4)}

.delivery-note{
  background:rgba(0,170,255,0.08);border:1px solid var(--border);
  border-radius:8px;padding:1rem;margin:1rem 0;
  font-size:0.7rem;color:var(--text);line-height:1.8;
}
.delivery-note strong{color:var(--cyan)}

.discord-block{
  background:rgba(88,101,242,0.1);border:1px solid rgba(88,101,242,0.3);
  border-radius:8px;padding:1rem;margin:1rem 0;
  display:flex;align-items:center;gap:0.75rem;
  font-size:0.72rem;color:var(--text);
}
.discord-tag{
  font-family:'Orbitron',monospace;font-size:0.8rem;color:#7289da;font-weight:700;
}

#paypal-modal-container{margin-top:1rem}
.paypal-loading{text-align:center;color:var(--muted);font-size:0.7rem;padding:1rem;letter-spacing:0.15em}

/* ── CONFIRM MODAL ── */
#confirm-overlay{
  position:fixed;inset:0;z-index:600;
  background:rgba(5,13,26,0.95);backdrop-filter:blur(12px);
  display:none;align-items:center;justify-content:center;
}
#confirm-overlay.open{display:flex}
.confirm-box{
  background:var(--bg2);border:1px solid rgba(0,255,136,0.4);
  border-radius:20px;padding:3rem;text-align:center;max-width:480px;
  box-shadow:0 0 80px rgba(0,255,136,0.15);
}
.confirm-icon{font-size:4rem;margin-bottom:1.5rem}
.confirm-title{
  font-family:'Orbitron',monospace;font-size:1.3rem;font-weight:700;
  color:var(--green);margin-bottom:1rem;
}
.confirm-text{font-size:0.8rem;color:var(--muted);line-height:2;margin-bottom:1.5rem}
.confirm-discord{
  font-family:'Or